{
  "name": "@twilight-explorer/indexer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "npm --prefix ../.. run db:generate && npm --prefix ../../packages/chain-client run build && npm --prefix ../../packages/config run build && npm --prefix ../../packages/db run build && npm --prefix ../../packages/decoder run build",
    "build": "tsc -p tsconfig.json",
    "pretypecheck": "npm run prebuild",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "npm run build",
    "test": "node --test",
    "dev": "npm run build && node dist/index.js",
    "start": "node dist/index.js",
    "project:coreslot-metadata": "node dist/projections/coreslot-metadata-cli.js",
    "project:coreslot-metadata:dev": "npm run build && node dist/projections/coreslot-metadata-cli.js",
    "project:coreslot-metadata:reset": "node dist/projections/reset-coreslot-metadata.js",
    "project:coreslot-lifecycle": "node dist/projections/coreslot-lifecycle-cli.js",
    "project:coreslot-lifecycle:dev": "npm run build && node dist/projections/coreslot-lifecycle-cli.js",
    "project:coreslot-lifecycle:reset": "node dist/projections/reset-coreslot-lifecycle.js",
    "project:coreslot-payout": "node dist/projections/coreslot-payout-cli.js",
    "project:coreslot-payout:dev": "npm run build && node dist/projections/coreslot-payout-cli.js",
    "project:coreslot-payout:reset": "node dist/projections/reset-coreslot-payout.js",
    "project:coreslot-params": "node dist/projections/coreslot-params-cli.js",
    "project:coreslot-params:dev": "npm run build && node dist/projections/coreslot-params-cli.js",
    "project:coreslot-params:reset": "node dist/projections/reset-coreslot-params.js",
    "project:coreslot-key-rotation": "node dist/projections/coreslot-key-rotation-cli.js",
    "project:coreslot-key-rotation:dev": "npm run build && node dist/projections/coreslot-key-rotation-cli.js",
    "project:coreslot-key-rotation:reset": "node dist/projections/reset-coreslot-key-rotation.js",
    "project:coreslot-temporal-map": "node dist/projections/coreslot-temporal-map-cli.js",
    "project:coreslot-temporal-map:dev": "npm run build && node dist/projections/coreslot-temporal-map-cli.js",
    "project:coreslot-temporal-map:reset": "node dist/projections/reset-coreslot-temporal-map.js",
    "project:coreslot-semantic": "node dist/projections/coreslot-semantic-rebuild-cli.js",
    "project:coreslot-semantic:dev": "npm run build && node dist/projections/coreslot-semantic-rebuild-cli.js",
    "project:coreslot-semantic:reset": "node dist/projections/reset-coreslot-semantic.js",
    "project:rewards": "node dist/projections/rewards-semantic-cli.js",
    "project:rewards:dev": "npm run build && node dist/projections/rewards-semantic-cli.js",
    "project:rewards:reset": "node dist/projections/reset-rewards-cli.js",
    "project:rewards-snapshot": "node dist/projections/rewards-snapshot-cli.js",
    "project:rewards-snapshot:dev": "npm run build && node dist/projections/rewards-snapshot-cli.js",
    "project:balance-snapshot": "node dist/projections/balance-snapshot-cli.js",
    "project:balance-snapshot:dev": "npm run build && node dist/projections/balance-snapshot-cli.js",
    "project:balance-snapshot:reset": "node dist/projections/reset-balance-snapshot-cli.js",
    "project:block-signatures": "node dist/projections/block-signatures-cli.js",
    "project:block-signatures:dev": "npm run build && node dist/projections/block-signatures-cli.js",
    "project:block-signatures:reset": "node dist/projections/reset-block-signatures-cli.js",
    "project:operator-signing-evidence": "node dist/projections/operator-signing-evidence-cli.js",
    "project:operator-signing-evidence:dev": "npm run build && node dist/projections/operator-signing-evidence-cli.js",
    "project:operator-signing-evidence:reset": "node dist/projections/reset-operator-signing-evidence-cli.js",
    "project:coreslot-liveness": "node dist/projections/coreslot-liveness-cli.js",
    "project:coreslot-liveness:dev": "npm run build && node dist/projections/coreslot-liveness-cli.js",
    "project:coreslot-liveness:reset": "node dist/projections/reset-coreslot-liveness-cli.js",
    "project:coreslot-liveness-summary": "node dist/projections/coreslot-liveness-summary-cli.js",
    "project:coreslot-liveness-summary:dev": "npm run build && node dist/projections/coreslot-liveness-summary-cli.js",
    "project:coreslot-liveness-summary:reset": "node dist/projections/reset-coreslot-liveness-summary-cli.js",
    "project:coreslot-health": "node dist/projections/coreslot-health-cli.js",
    "project:coreslot-health:dev": "npm run build && node dist/projections/coreslot-health-cli.js",
    "project:coreslot-health:reset": "node dist/projections/reset-coreslot-health-cli.js",
    "project:proposer-attribution": "node dist/projections/proposer-attribution-cli.js",
    "project:proposer-attribution:dev": "npm run build && node dist/projections/proposer-attribution-cli.js",
    "project:proposer-attribution:reset": "node dist/projections/reset-proposer-attribution-cli.js"
  },
  "dependencies": {
    "@twilight-explorer/chain-client": "0.0.0",
    "@twilight-explorer/config": "0.0.0",
    "@twilight-explorer/db": "0.0.0",
    "@twilight-explorer/decoder": "0.0.0"
  }
}
