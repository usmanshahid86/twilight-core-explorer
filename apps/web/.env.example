# Base URL of the Phase 9 public API the web app reads from.
# Must be NEXT_PUBLIC_ because all API fetching is client-side (client-leaning posture).
# Local default matches the API's default port (apps/api DEFAULT_PORT = 8080).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Optional: visual theme. Defaults to "auction" (the locked Twilight theme). "legacy" is the
# alternate mempool-style palette carried in globals.css.
# NEXT_PUBLIC_UI_THEME=auction
