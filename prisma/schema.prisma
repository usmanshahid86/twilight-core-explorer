generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Block {
  height             BigInt   @id
  hash               String?  @unique
  time               DateTime?
  chainId            String?
  proposerAddress    String?
  appHash            String?
  validatorsHash     String?
  nextValidatorsHash String?
  lastBlockHash      String?
  txCount            Int
  rawJson            Json
  createdAt          DateTime @default(now())

  @@index([time])
  @@index([proposerAddress])
  @@index([chainId, height])
}

model ExplorerTransaction {
  hash                String   @id
  height              BigInt
  index               Int
  code                Int?
  codespace           String?
  status              String
  gasWanted           BigInt?
  gasUsed             BigInt?
  memo                String?
  feeJson             Json?
  signerAddressesJson Json
  messageTypesJson    Json
  rawTx               Json?
  rawResultJson       Json
  createdAt           DateTime @default(now())

  @@index([height, index])
  @@index([status])
  @@index([createdAt])
}

model Message {
  id          BigInt   @id @default(autoincrement())
  txHash      String
  height      BigInt
  msgIndex    Int
  typeUrl     String
  module      String?
  typeName    String?
  decodedJson Json?
  rawJson     Json?
  decodeError String?
  createdAt   DateTime @default(now())

  @@unique([txHash, msgIndex])
  @@index([height])
  @@index([typeUrl])
  @@index([module])
  @@index([decodeError])
}

model Event {
  id             BigInt   @id @default(autoincrement())
  eventKey       String   @unique
  height         BigInt
  txHash         String?
  txIndex        Int?
  msgIndex       Int?
  eventIndex     Int
  phase          String
  type           String
  attributesJson Json
  module         String?
  keyFieldsJson  Json?
  createdAt      DateTime @default(now())

  @@index([height])
  @@index([txHash])
  @@index([type])
  @@index([module])
}

model Account {
  address        String   @id
  firstSeenHeight BigInt?
  lastSeenHeight  BigInt?
  txCount        Int      @default(0)
  accountKind    String?
  rawAccountJson Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([lastSeenHeight])
  @@index([accountKind])
}

model IndexerCursor {
  chainId           String   @id
  lastIndexedHeight BigInt
  lastIndexedHash   String?
  latestChainHeight BigInt?
  status            String
  updatedAt         DateTime @updatedAt
  error             String?

  @@index([updatedAt])
  @@index([status])
}

model DecodeFailure {
  id          BigInt   @id @default(autoincrement())
  height      BigInt
  txHash      String?
  msgIndex    Int?
  eventIndex  Int?
  typeUrl     String?
  eventType   String?
  failureKind String
  rawJson     Json?
  rawBase64   String?
  decodeError String
  resolved    Boolean  @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([height])
  @@index([txHash])
  @@index([typeUrl])
  @@index([eventType])
  @@index([failureKind])
  @@index([resolved])
}

model ProjectionCursor {
  projectionName      String
  chainId             String
  lastProjectedHeight BigInt
  status              String
  updatedAt           DateTime @updatedAt
  error               String?

  @@id([projectionName, chainId])
  @@index([status])
  @@index([updatedAt])
}

model ProjectionFailure {
  id              BigInt   @id @default(autoincrement())
  failureKey      String?  @unique
  projectionName  String
  module          String?
  sourceHeight    BigInt
  sourceTxHash    String?
  sourceMsgIndex  Int?
  sourceMessageId BigInt?
  sourceEventId   BigInt?
  typeUrl         String?
  eventType       String?
  failureKind     String
  rawMessageJson  Json?
  rawEventJson    Json?
  error           String
  resolved        Boolean  @default(false)
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())

  @@index([projectionName])
  @@index([module])
  @@index([sourceHeight])
  @@index([sourceTxHash])
  @@index([failureKind])
  @@index([resolved])
}

model CoreSlotProjection {
  slotId              BigInt   @id
  status              String?
  operatorAddress     String?
  payoutAddress       String?
  consensusAddress    String?
  consensusPubkeyJson Json?
  metadataJson        Json?
  rewardWeight        String?
  consensusPower      BigInt?
  createdHeight       BigInt?
  updatedHeight       BigInt
  removedHeight       BigInt?
  rawSnapshotJson     Json?
  lastSourceHeight    BigInt
  lastSourceTxHash    String?
  lastSourceMsgIndex  Int?
  lastSourceMessageId BigInt?
  lastSourceEventId   BigInt?
  createdAt           DateTime @default(now())
  updatedAtDb         DateTime @updatedAt

  @@index([status])
  @@index([operatorAddress])
  @@index([consensusAddress])
  @@index([updatedHeight])
}

model CoreSlotMetadataChange {
  id              BigInt   @id @default(autoincrement())
  slotId          BigInt
  operatorAddress String
  height          BigInt
  txHash          String
  msgIndex        Int
  metadataJson    Json
  sourceMessageId BigInt   @unique
  sourceEventId   BigInt?
  rawMessageJson  Json
  rawEventJson    Json?
  createdAt       DateTime @default(now())

  @@index([slotId, height])
  @@index([operatorAddress])
  @@index([txHash])
  @@index([sourceEventId])
}

model CoreSlotLifecycleEvent {
  id                BigInt   @id @default(autoincrement())
  sourceEventId     BigInt   @unique
  sourceMessageId   BigInt?
  height            BigInt
  txHash            String?
  msgIndex          Int?
  slotId            BigInt?
  eventType         String
  oldStatus         String?
  newStatus         String?
  operatorAddress   String?
  consensusAddress  String?
  power             BigInt?
  reason            String?
  evidenceReference String?
  authority         String?
  rawEventJson      Json
  rawMessageJson    Json?
  createdAt         DateTime @default(now())

  @@index([slotId, height])
  @@index([eventType])
  @@index([operatorAddress])
  @@index([consensusAddress])
  @@index([txHash])
}

model CoreSlotPayoutChange {
  id               BigInt   @id @default(autoincrement())
  slotId           BigInt
  operatorAddress  String
  newPayoutAddress String
  height           BigInt
  txHash           String
  msgIndex         Int
  sourceMessageId  BigInt   @unique
  sourceEventId    BigInt?
  rawMessageJson   Json
  rawEventJson     Json?
  createdAt        DateTime @default(now())

  @@index([slotId, height])
  @@index([operatorAddress])
  @@index([newPayoutAddress])
  @@index([txHash])
  @@index([sourceEventId])
}

model CoreSlotParameterChange {
  id              BigInt   @id @default(autoincrement())
  height          BigInt
  txHash          String
  msgIndex        Int
  authority       String
  paramsJson      Json
  sourceMessageId BigInt   @unique
  sourceEventId   BigInt?
  rawMessageJson  Json
  rawEventJson    Json?
  createdAt       DateTime @default(now())

  @@index([height])
  @@index([authority])
  @@index([txHash])
  @@index([sourceEventId])
}

model CoreSlotConsensusWindow {
  id                  BigInt   @id @default(autoincrement())
  slotId              BigInt
  operatorAddress     String?
  consensusAddress    String
  status              String // ACTIVE signing window
  consensusPower      BigInt?
  effectiveFromHeight BigInt
  effectiveToHeight   BigInt?
  openedByKind        String // lifecycle | key_rotation | inferred
  openedByEventId     BigInt?
  openedByRotationId  BigInt?
  openedByLifecycleId BigInt?
  closedByKind        String?
  closedByEventId     BigInt?
  closedByRotationId  BigInt?
  closedByLifecycleId BigInt?
  rawOpenJson         Json?
  rawCloseJson        Json?
  createdAt           DateTime @default(now())
  updatedAtDb         DateTime @updatedAt

  @@index([slotId])
  @@index([operatorAddress])
  @@index([consensusAddress])
  @@index([effectiveFromHeight])
  @@index([effectiveToHeight])
  @@index([status])
  @@index([slotId, effectiveFromHeight])
  @@index([consensusAddress, effectiveFromHeight])
}

model CoreSlotConsensusKeyRotation {
  id                     BigInt   @id @default(autoincrement())
  slotId                 BigInt
  operatorAddress        String?
  oldConsensusAddress    String?
  newConsensusAddress    String?
  status                 String // requested | applied | cancelled | immediate_applied
  requestedHeight        BigInt?
  effectiveHeight        BigInt?
  appliedHeight          BigInt?
  cancelledHeight        BigInt?
  power                  BigInt?
  reason                 String?
  sourceMessageId        BigInt?
  sourceRequestEventId   BigInt?  @unique
  sourceAppliedEventId   BigInt?  @unique
  sourceCancelledEventId BigInt?  @unique
  requestTxHash          String?
  requestMsgIndex        Int?
  appliedTxHash          String?
  appliedMsgIndex        Int?
  cancelledTxHash        String?
  cancelledMsgIndex      Int?
  rawMessageJson         Json?
  rawRequestEventJson    Json?
  rawAppliedEventJson    Json?
  rawCancelledEventJson  Json?
  createdAt              DateTime @default(now())
  updatedAtDb            DateTime @updatedAt

  @@index([slotId])
  @@index([operatorAddress])
  @@index([oldConsensusAddress])
  @@index([newConsensusAddress])
  @@index([status])
  @@index([effectiveHeight])
  @@index([requestedHeight])
  @@index([appliedHeight])
  @@index([cancelledHeight])
  @@index([sourceMessageId])
}
