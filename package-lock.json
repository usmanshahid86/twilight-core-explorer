      "link": true
    },
    "packages/chain-client": {
      "name": "@twilight-explorer/chain-client",
      "version": "0.0.0"
    },
    "packages/config": {
      "name": "@twilight-explorer/config",
      "version": "0.0.0"
    }
  }
}
