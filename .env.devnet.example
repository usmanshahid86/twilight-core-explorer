# ─────────────────────────────────────────────────────────────────────────────
# .env.devnet.example — single env contract for the local "see it" stack against
# the LIVE devnet (docker-compose.devnet.yml + runbook §9). Copy and fill in:
#
#     cp .env.devnet.example .env.devnet
#     docker compose -f docker-compose.devnet.yml --env-file .env.devnet up -d --build
#
# `.env.devnet` is gitignored — never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── Devnet endpoints (pre-filled; verified reachable 2026-06-29) ─────────────────
# RPC must be http(s):// (NOT tcp://). CHAIN_ID MUST match the node or the indexer's
# chain-id guard aborts ingest (unset → silently defaults to twilight-localnet-1).
COMET_RPC_URL=http://16.192.99.123:26657
REST_URL=http://16.192.99.123:1317
CHAIN_ID=twilight-devnet-1

# ── Postgres (the `postgres` container) ─────────────────────────────────────────
POSTGRES_USER=twilight
POSTGRES_PASSWORD=twilight
POSTGRES_DB=twilight_explorer
POSTGRES_PORT=5432

# ── Database URLs (services reach Postgres at the compose hostname `postgres`) ────
# Indexer writes (read-WRITE role):
DATABASE_URL=postgresql://twilight:twilight@postgres:5432/twilight_explorer?schema=public
# API reads. For a PUBLIC deploy use a least-privilege read-only role (runbook §4);
# for the local see-it, reusing the same role is fine.
API_DATABASE_URL=postgresql://twilight:twilight@postgres:5432/twilight_explorer?schema=public

# ── API (production posture — required even locally so it mirrors AWS) ────────────
API_ENV=production
# CORS_ORIGINS MUST list the web origin or the browser is CORS-blocked (prod denies by default).
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_ENABLED=true
API_PORT=8080
APP_VERSION=devnet

# ── Web (Next.js) ────────────────────────────────────────────────────────────────
# ⚠ BUILD-TIME, inlined into the browser bundle → must be the origin the BROWSER uses
#   to reach the API (host-published port), NOT the compose-internal `api:8080`.
#   Changing this requires `up --build` to rebuild the web image.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
WEB_PORT=3000

# ── Loop cadences ────────────────────────────────────────────────────────────────
# Ingest ticks fast to keep lag low; the projector follows on a slower cadence (it's a
# DB→DB transform). During the initial backfill the projector fills the UI progressively.
INGEST_INTERVAL_SECONDS=15
PROJECT_INTERVAL_SECONDS=60
